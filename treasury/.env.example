PORT=3200

DB_HOST=localhost
DB_PORT=5432
DB_NAME=agroasys_treasury
DB_USER=cotsel_treasury_app
DB_PASSWORD=local-treasury-runtime-password
DB_MIGRATION_USER=cotsel_treasury_migrator
DB_MIGRATION_PASSWORD=local-treasury-migration-password

INDEXER_GRAPHQL_URL=http://localhost:4350/graphql
TREASURY_INGEST_BATCH_SIZE=100
TREASURY_INGEST_MAX_EVENTS=2000

# Optional settlement runtime for live confirmation-stage gating.
SETTLEMENT_RUNTIME=
RPC_URL=
RPC_FALLBACK_URLS=
CHAIN_ID=
EXPLORER_BASE_URL=

# Optional reconciliation DB for payout/export gating. When unset, treasury
# will keep entries blocked because reconciliation state cannot be proven.
RECONCILIATION_DB_HOST=
RECONCILIATION_DB_PORT=
RECONCILIATION_DB_NAME=
RECONCILIATION_DB_USER=
RECONCILIATION_DB_PASSWORD=

# Disable only for isolated local development. Production defaults to true.
AUTH_ENABLED=false
API_KEYS_JSON=[]
# Example: API_KEYS_JSON=[{"id":"treasury-internal","secret":"replace-with-secret","active":true}]
# NOTE: active must be explicit boolean true/false for each key.
HMAC_SECRET=
AUTH_MAX_SKEW_SECONDS=300
AUTH_NONCE_TTL_SECONDS=600
NONCE_STORE=inmemory
REDIS_URL=
NONCE_TTL_SECONDS=600
TREASURY_CORS_ALLOWED_ORIGINS=
TREASURY_CORS_ALLOW_NO_ORIGIN=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=
