# Copy to .env.staging-e2e-real for staging-grade real indexer validation.
# This profile uses the real indexer pipeline (indexer-migrate + indexer-pipeline + indexer-graphql).

# In-network GraphQL endpoints (never localhost inside containers)
RECONCILIATION_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
TREASURY_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
ORACLE_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql

# Real indexer pipeline inputs
INDEXER_GATEWAY_URL=https://v2.archive.subsquid.io/network/asset-hub-paseo
INDEXER_RPC_ENDPOINT=https://sys.ibp.network/asset-hub-paseo 
INDEXER_START_BLOCK=5361048
INDEXER_RATE_LIMIT=10
INDEXER_GRAPHQL_PORT=4350

# Chain context used by validation reporting
STAGING_E2E_REAL_NETWORK_NAME=asset-hub-paseo
STAGING_E2E_REAL_CHAIN_ID=420420421

# Reconciliation/oracle RPC for staging-grade checks (use non-localhost by default)
RECONCILIATION_RPC_URL=https://services.polkadothub-rpc.com/testnet
ORACLE_RPC_URL=https://services.polkadothub-rpc.com/testnet
RECONCILIATION_CHAIN_ID=420420417
ORACLE_CHAIN_ID=420420417

# Enforce non-localhost indexer URL when reconciliation runs in containerized staging profile
RECONCILIATION_REQUIRE_CONTAINER_SAFE_INDEXER_URL=true

# Optional strictness for release candidates
# When true, the gate fails if indexer has zero trades for the configured contract scope.
STAGING_E2E_REAL_REQUIRE_INDEXED_DATA=false
STAGING_E2E_REAL_DYNAMIC_START_BLOCK=true
STAGING_E2E_REAL_START_BLOCK_BACKOFF=250
STAGING_E2E_REAL_LAG_WARMUP_SECONDS=180
STAGING_E2E_REAL_LAG_POLL_SECONDS=5


# service auth defaults (disabled by default)
RICARDIAN_HMAC_SECRET=
TREASURY_HMAC_SECRET=
RICARDIAN_NONCE_STORE=postgres
TREASURY_NONCE_STORE=postgres

# Replace with deployed addresses for full staging parity.
# Keep quotes to prevent accidental shell coercion when sourced by helper scripts.
RECONCILIATION_ESCROW_ADDRESS='0x0000000000000000000000000000000000000000'
RECONCILIATION_USDC_ADDRESS='0x0000000000000000000000000000000000000000'
ORACLE_ESCROW_ADDRESS='0x0000000000000000000000000000000000000000'
ORACLE_USDC_ADDRESS='0x0000000000000000000000000000000000000000'
INDEXER_CONTRACT_ADDRESS='0x0000000000000000000000000000000000000000'

# Gate thresholds
STAGING_E2E_MAX_INDEXER_LAG_BLOCKS=500
STAGING_E2E_DRIFT_SUMMARY_LIMIT=10

# Asset conversion fee-path validation (set tx hashes after running live probe)
STAGING_E2E_REAL_FEE_PATH_EXPECTED_BEHAVIOR=usdc-preferred
STAGING_E2E_REAL_FEE_PATH_ALLOW_NATIVE_FALLBACK=true
STAGING_E2E_REAL_FEE_PATH_CREATE_TX_HASH=
STAGING_E2E_REAL_FEE_PATH_SETTLEMENT_TX_HASHES=
