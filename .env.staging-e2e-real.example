# Copy to .env.staging-e2e-real for staging-grade real indexer validation.
# This profile uses the real indexer pipeline (indexer-migrate + indexer-pipeline + indexer-graphql).
#
# Dashboard gateway remote staging coordinates are recorded in:
# - docs/runbooks/dashboard-gateway-operations.md
# - docs/runbooks/dashboard-api-gateway-boundary.md
# - Cotsel issue #234
# Do not copy the public dashboard gateway or auth-service URLs into this file.
# This profile remains the internal containerized pilot contract for the staging stack.
GATEWAY_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
GATEWAY_INDEXER_REQUEST_TIMEOUT_MS=5000
GATEWAY_SETTLEMENT_RUNTIME=base-sepolia
GATEWAY_RPC_URL=https://managed-base-sepolia-rpc-primary.example.invalid
GATEWAY_RPC_FALLBACK_URLS=https://managed-base-sepolia-rpc-fallback.example.invalid
GATEWAY_CHAIN_ID=84532
GATEWAY_EXPLORER_BASE_URL=https://sepolia-explorer.base.org/tx/

# In-network GraphQL endpoints (never localhost inside containers)
RECONCILIATION_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
TREASURY_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
ORACLE_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql

# Active Base Sepolia managed-provider inputs.
# INDEXER_GATEWAY_URL is optional when the indexer runs directly against RPC.
INDEXER_GATEWAY_URL=https://managed-base-sepolia-indexer.example.invalid
INDEXER_RPC_ENDPOINT=https://managed-base-sepolia-rpc-primary.example.invalid
INDEXER_START_BLOCK=39588005
INDEXER_RATE_LIMIT=10
INDEXER_RPC_CAPACITY=
INDEXER_RPC_MAX_BATCH_CALL_SIZE=
INDEXER_RPC_REQUEST_TIMEOUT_MS=
INDEXER_RPC_RETRY_ATTEMPTS=
INDEXER_RPC_HEAD_POLL_INTERVAL_MS=
INDEXER_RPC_INGEST_DISABLED=false
INDEXER_RPC_BLOCK_SPLIT_SIZE=10
FINALITY_CONFIRMATION_BLOCKS=1
INDEXER_GRAPHQL_PORT=4350

# Chain context used by validation reporting
STAGING_E2E_REAL_NETWORK_NAME='Base Sepolia'
STAGING_E2E_REAL_CHAIN_ID=84532

# Reconciliation/oracle pilot runtime (managed primary + independent fallback)
RECONCILIATION_SETTLEMENT_RUNTIME=base-sepolia
RECONCILIATION_RPC_URL=https://managed-base-sepolia-rpc-primary.example.invalid
RECONCILIATION_RPC_FALLBACK_URLS=https://managed-base-sepolia-rpc-fallback.example.invalid
RECONCILIATION_CHAIN_ID=84532
ORACLE_SETTLEMENT_RUNTIME=base-sepolia
ORACLE_RPC_URL=https://managed-base-sepolia-rpc-primary.example.invalid
ORACLE_RPC_FALLBACK_URLS=https://managed-base-sepolia-rpc-fallback.example.invalid
ORACLE_CHAIN_ID=84532

# notifications runtime wiring (staging-e2e-real profile defaults)
ORACLE_NOTIFICATIONS_ENABLED=false
ORACLE_NOTIFICATIONS_WEBHOOK_URL=
ORACLE_NOTIFICATIONS_COOLDOWN_MS=300000
ORACLE_NOTIFICATIONS_REQUEST_TIMEOUT_MS=5000
RECONCILIATION_NOTIFICATIONS_ENABLED=false
RECONCILIATION_NOTIFICATIONS_WEBHOOK_URL=
RECONCILIATION_NOTIFICATIONS_COOLDOWN_MS=300000
RECONCILIATION_NOTIFICATIONS_REQUEST_TIMEOUT_MS=5000

# Enforce non-localhost indexer URL when reconciliation runs in containerized staging profile
RECONCILIATION_REQUIRE_CONTAINER_SAFE_INDEXER_URL=true

# Optional strictness for release candidates
# When true, the gate fails if indexer has zero trades for the configured contract scope.
STAGING_E2E_REAL_REQUIRE_INDEXED_DATA=false
STAGING_E2E_REAL_DYNAMIC_START_BLOCK=true
STAGING_E2E_REAL_START_BLOCK_BACKOFF=250
STAGING_E2E_REAL_LAG_WARMUP_SECONDS=180
STAGING_E2E_REAL_LAG_POLL_SECONDS=5


# service auth defaults (disabled by default)
RICARDIAN_HMAC_SECRET=
TREASURY_HMAC_SECRET=
RICARDIAN_NONCE_STORE=postgres
TREASURY_NONCE_STORE=postgres

# Replace with deployed addresses for full staging parity.
# Keep quotes to prevent accidental shell coercion when sourced by helper scripts.
RECONCILIATION_ESCROW_ADDRESS='0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A'
RECONCILIATION_USDC_ADDRESS='0x036CbD53842c5426634e7929541eC2318f3dCF7e'
ORACLE_ESCROW_ADDRESS='0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A'
ORACLE_USDC_ADDRESS='0x036CbD53842c5426634e7929541eC2318f3dCF7e'
GATEWAY_ESCROW_ADDRESS='0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A'
GATEWAY_USDC_ADDRESS='0x036CbD53842c5426634e7929541eC2318f3dCF7e'
INDEXER_CONTRACT_ADDRESS='0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A'

# Gate thresholds
STAGING_E2E_MAX_INDEXER_LAG_BLOCKS=500
STAGING_E2E_DRIFT_SUMMARY_LIMIT=10

# Asset conversion fee-path validation (set tx hashes after running live probe)
STAGING_E2E_REAL_FEE_PATH_EXPECTED_BEHAVIOR=usdc-preferred
STAGING_E2E_REAL_FEE_PATH_ALLOW_NATIVE_FALLBACK=true
STAGING_E2E_REAL_FEE_PATH_CREATE_TX_HASH=
STAGING_E2E_REAL_FEE_PATH_SETTLEMENT_TX_HASHES=
