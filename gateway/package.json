{
  "name": "gateway",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run copy-files",
    "prebuild": "npm --prefix ../sdk run build",
    "copy-files": "mkdir -p dist/database dist/openapi && cp src/database/schema.sql dist/database/ && cp ../docs/api/cotsel-dashboard-gateway.openapi.yml dist/openapi/",
    "execute:governance-action": "ts-node src/executor/runGovernanceAction.ts",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "pretest": "npm --prefix ../sdk run build",
    "test": "jest --runInBand",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agroasys/shared-db": "*",
    "@agroasys/shared-edge": "*",
    "@agroasys/shared-auth": "*",
    "@agroasys/sdk": "*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ethers": "^6.4.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "ajv": "^8.17.1",
    "jest": "^30.3.0",
    "js-yaml": "^4.1.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": ">=6.0.2"
  },
  "license": "Apache-2.0"
}
