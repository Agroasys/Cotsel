{
  "name": "gateway",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run copy-files",
    "prebuild": "npm --prefix ../sdk run build",
    "copy-files": "mkdir -p dist/database dist/openapi && cp src/database/schema.sql dist/database/ && cp ../docs/api/cotsel-dashboard-gateway.openapi.yml dist/openapi/",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "pretest": "npm --prefix ../sdk run build",
    "test": "jest --runInBand",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agroasys/shared-db": "*",
    "@agroasys/shared-edge": "*",
    "@agroasys/shared-auth": "*",
    "@agroasys/sdk": "*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "ajv": "^8.20.0",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.1",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": ">=7.0.2"
  },
  "license": "Apache-2.0"
}
