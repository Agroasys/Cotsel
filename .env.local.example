# Copy to .env.local for fast local profile overrides

# local profile uses lightweight indexer responder
RECONCILIATION_INDEXER_GRAPHQL_URL=http://indexer:4350/graphql
TREASURY_INDEXER_GRAPHQL_URL=http://indexer:4350/graphql
ORACLE_INDEXER_GRAPHQL_URL=http://indexer:4350/graphql

# local hardhat/evm defaults
RECONCILIATION_RPC_URL=http://hardhat:8545
ORACLE_RPC_URL=http://hardhat:8545
RECONCILIATION_CHAIN_ID=31337
ORACLE_CHAIN_ID=31337

# service auth defaults (disabled by default)
RICARDIAN_HMAC_SECRET=
TREASURY_HMAC_SECRET=
RICARDIAN_NONCE_STORE=postgres
TREASURY_NONCE_STORE=postgres

# 0x values kept explicit for strict parser validation
RECONCILIATION_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
RECONCILIATION_USDC_ADDRESS=0x0000000000000000000000000000000000000000
ORACLE_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
ORACLE_USDC_ADDRESS=0x0000000000000000000000000000000000000000
INDEXER_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Asset conversion fee-path validation (local-dev expects deterministic native fallback)
LOCAL_DEV_FEE_PATH_EXPECTED_BEHAVIOR=native-fallback
LOCAL_DEV_FEE_PATH_ALLOW_NATIVE_FALLBACK=true
LOCAL_DEV_FEE_PATH_CREATE_TX_HASH=
LOCAL_DEV_FEE_PATH_SETTLEMENT_TX_HASHES=
