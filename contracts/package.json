{
  "name": "contracts",
  "version": "1.0.0",
  "main": "index.js",
  "license": "Apache-2.0",
  "scripts": {
    "compile": "hardhat compile --force",
    "prelint": "hardhat compile",
    "deploy:base-sepolia": "npx hardhat run scripts/deploy-base.ts --network base-sepolia",
    "deploy:base-mainnet": "npx hardhat run scripts/deploy-base.ts --network base-mainnet",
    "verify:base-sepolia": "npx hardhat verify --network base-sepolia",
    "verify:base-mainnet": "npx hardhat verify --network base-mainnet",
    "compile:polkavm:historical": "hardhat --config hardhat.polkavm.historical.config.ts compile --network polkadotTestnet --force",
    "deploy:polkavm:historical": "npx hardhat --config hardhat.polkavm.historical.config.ts clean && npx hardhat --config hardhat.polkavm.historical.config.ts compile --network polkadotTestnet --force && npx hardhat --config hardhat.polkavm.historical.config.ts run scripts/deploy-polkavm.ts --network polkadotTestnet",
    "test": "hardhat test",
    "test:foundry": "cd foundry && forge test -vvv",
    "coverage": "hardhat coverage",
    "pretypecheck": "hardhat compile",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "3.1.3",
    "@nomicfoundation/hardhat-ignition": "0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@nomicfoundation/hardhat-verify": "2.1.3",
    "@parity/hardhat-polkadot": "0.2.7",
    "@parity/hardhat-polkadot-resolc": "0.2.3",
    "@parity/resolc": "1.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/mocha": ">=9.1.0",
    "@types/node": ">=25.5.2",
    "chai": "^4.5.0",
    "ethers": "^6.4.0",
    "hardhat": "2.28.6",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": ">=8.0.0",
    "typechain": "^8.3.0",
    "typescript": ">=6.0.2"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "cookie": "^1.1.1",
    "lodash": "^4.17.23",
    "tmp": "^0.2.4"
  }
}
