# Global Docker compose defaults (copy to .env)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agroasys
POSTGRES_PORT=5432
REDIS_PORT=6379

AUTH_DB_NAME=agroasys_auth
RICARDIAN_DB_NAME=agroasys_ricardian
TREASURY_DB_NAME=agroasys_treasury
RECONCILIATION_DB_NAME=agroasys_reconciliation
ORACLE_DB_NAME=agroasys_oracle
INDEXER_DB_NAME=agroasys_indexer
GATEWAY_DB_NAME=agroasys_gateway

# Service-scoped Postgres roles. Runtime roles are least-privilege app users.
# Migration roles own schema changes and grant runtime access during bootstrap.
AUTH_DB_RUNTIME_USER=cotsel_auth_app
AUTH_DB_RUNTIME_PASSWORD=local-auth-runtime-password
AUTH_DB_MIGRATION_USER=cotsel_auth_migrator
AUTH_DB_MIGRATION_PASSWORD=local-auth-migration-password
RICARDIAN_DB_RUNTIME_USER=cotsel_ricardian_app
RICARDIAN_DB_RUNTIME_PASSWORD=local-ricardian-runtime-password
RICARDIAN_DB_MIGRATION_USER=cotsel_ricardian_migrator
RICARDIAN_DB_MIGRATION_PASSWORD=local-ricardian-migration-password
TREASURY_DB_RUNTIME_USER=cotsel_treasury_app
TREASURY_DB_RUNTIME_PASSWORD=local-treasury-runtime-password
TREASURY_DB_MIGRATION_USER=cotsel_treasury_migrator
TREASURY_DB_MIGRATION_PASSWORD=local-treasury-migration-password
RECONCILIATION_DB_RUNTIME_USER=cotsel_reconciliation_app
RECONCILIATION_DB_RUNTIME_PASSWORD=local-reconciliation-runtime-password
RECONCILIATION_DB_MIGRATION_USER=cotsel_reconciliation_migrator
RECONCILIATION_DB_MIGRATION_PASSWORD=local-reconciliation-migration-password
ORACLE_DB_RUNTIME_USER=cotsel_oracle_app
ORACLE_DB_RUNTIME_PASSWORD=local-oracle-runtime-password
ORACLE_DB_MIGRATION_USER=cotsel_oracle_migrator
ORACLE_DB_MIGRATION_PASSWORD=local-oracle-migration-password
GATEWAY_DB_RUNTIME_USER=cotsel_gateway_app
GATEWAY_DB_RUNTIME_PASSWORD=local-gateway-runtime-password
GATEWAY_DB_MIGRATION_USER=cotsel_gateway_migrator
GATEWAY_DB_MIGRATION_PASSWORD=local-gateway-migration-password

AUTH_PORT=3005
AUTH_SESSION_TTL_SECONDS=3600
# Compatibility-only wallet login. Enable only for local development or tests.
LEGACY_WALLET_LOGIN_ENABLED=false
AUTH_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_CORS_ALLOW_NO_ORIGIN=false
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_REDIS_URL=
TRUSTED_SESSION_EXCHANGE_ENABLED=false
TRUSTED_SESSION_EXCHANGE_API_KEYS_JSON=
TRUSTED_SESSION_EXCHANGE_MAX_SKEW_SECONDS=300
TRUSTED_SESSION_EXCHANGE_NONCE_TTL_SECONDS=600
RICARDIAN_PORT=3100
TREASURY_PORT=3200
ORACLE_PORT=3001
INDEXER_GRAPHQL_PORT=4350
GATEWAY_PORT=3600

# Reconciliation strict config
RECONCILIATION_ENABLED=true
RECONCILIATION_DAEMON_INTERVAL_MS=60000
RECONCILIATION_BATCH_SIZE=100
RECONCILIATION_MAX_TRADES_PER_RUN=1000
RECONCILIATION_RPC_URL=http://host.docker.internal:8545
RECONCILIATION_CHAIN_ID=31337
RECONCILIATION_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
RECONCILIATION_USDC_ADDRESS=0x0000000000000000000000000000000000000000
RECONCILIATION_INDEXER_GRAPHQL_URL=http://indexer:4350/graphql
RECONCILIATION_REQUIRE_CONTAINER_SAFE_INDEXER_URL=false
RECONCILIATION_NOTIFICATIONS_ENABLED=false
RECONCILIATION_NOTIFICATIONS_WEBHOOK_URL=
RECONCILIATION_NOTIFICATIONS_COOLDOWN_MS=300000
RECONCILIATION_NOTIFICATIONS_REQUEST_TIMEOUT_MS=5000
RECONCILIATION_HEALTH_PORT=9090

# Oracle strict config
ORACLE_API_KEY=local-api-key
ORACLE_HMAC_SECRET=local-hmac-secret
ORACLE_CORS_ALLOWED_ORIGINS=
ORACLE_CORS_ALLOW_NO_ORIGIN=false
ORACLE_RATE_LIMIT_ENABLED=true
ORACLE_RATE_LIMIT_REDIS_URL=
ORACLE_RPC_URL=http://host.docker.internal:8545
ORACLE_CHAIN_ID=31337
ORACLE_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
ORACLE_USDC_ADDRESS=0x0000000000000000000000000000000000000000
ORACLE_PRIVATE_KEY=0x0123456789012345678901234567890123456789012345678901234567890123
ORACLE_INDEXER_GRAPHQL_URL=http://indexer:4350/graphql
ORACLE_RETRY_ATTEMPTS=3
ORACLE_RETRY_DELAY=1000
ORACLE_NOTIFICATIONS_ENABLED=false
ORACLE_NOTIFICATIONS_WEBHOOK_URL=
ORACLE_NOTIFICATIONS_COOLDOWN_MS=300000
ORACLE_NOTIFICATIONS_REQUEST_TIMEOUT_MS=5000
ORACLE_MANUAL_APPROVAL_ENABLED=false

# Ricardian config
# Local docker example only. Production must not disable internal auth.
RICARDIAN_AUTH_ENABLED=false
RICARDIAN_API_KEYS_JSON=
RICARDIAN_HMAC_SECRET=
RICARDIAN_AUTH_MAX_SKEW_SECONDS=300
RICARDIAN_AUTH_NONCE_TTL_SECONDS=600
RICARDIAN_NONCE_STORE=inmemory
RICARDIAN_NONCE_REDIS_URL=
RICARDIAN_NONCE_TTL_SECONDS=600
RICARDIAN_CORS_ALLOWED_ORIGINS=
RICARDIAN_CORS_ALLOW_NO_ORIGIN=false
RICARDIAN_RATE_LIMIT_ENABLED=true
RICARDIAN_RATE_LIMIT_REDIS_URL=

# Treasury config
TREASURY_INDEXER_GRAPHQL_URL=http://indexer:4350/graphql
TREASURY_INGEST_BATCH_SIZE=100
TREASURY_INGEST_MAX_EVENTS=2000
# Local docker example only. Production must not disable internal auth.
TREASURY_AUTH_ENABLED=false
TREASURY_API_KEYS_JSON=
TREASURY_HMAC_SECRET=
TREASURY_AUTH_MAX_SKEW_SECONDS=300
TREASURY_AUTH_NONCE_TTL_SECONDS=600
TREASURY_NONCE_STORE=inmemory
TREASURY_NONCE_REDIS_URL=
TREASURY_NONCE_TTL_SECONDS=600
TREASURY_CORS_ALLOWED_ORIGINS=
TREASURY_CORS_ALLOW_NO_ORIGIN=false
TREASURY_RATE_LIMIT_ENABLED=true
TREASURY_RATE_LIMIT_REDIS_URL=

# Dashboard gateway config
# Defaults below are for local/docker parity.
# Approved remote staging coordinates are recorded in:
# - docs/runbooks/dashboard-gateway-operations.md
# - docs/runbooks/dashboard-api-gateway-boundary.md
# - Cotsel issue #234
GATEWAY_AUTH_BASE_URL=http://auth:3005
GATEWAY_AUTH_REQUEST_TIMEOUT_MS=5000
GATEWAY_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
GATEWAY_INDEXER_REQUEST_TIMEOUT_MS=5000
GATEWAY_SETTLEMENT_RUNTIME=
GATEWAY_RPC_URL=http://host.docker.internal:8545
GATEWAY_RPC_FALLBACK_URLS=
GATEWAY_RPC_READ_TIMEOUT_MS=8000
GATEWAY_CHAIN_ID=31337
GATEWAY_EXPLORER_BASE_URL=
GATEWAY_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
GATEWAY_USDC_ADDRESS=0x0000000000000000000000000000000000000000
# Keep read-only until governance/compliance read endpoints are verified.
GATEWAY_ENABLE_MUTATIONS=false
# When writes are enabled later, populate this with the concrete local auth principal IDs
# for the approved writers (Aston, czpyioe). Do not guess identifiers.
GATEWAY_WRITE_ALLOWLIST=
GATEWAY_GOVERNANCE_QUEUE_TTL_SECONDS=86400
GATEWAY_COMMIT_SHA=local-dev
GATEWAY_BUILD_TIME=2026-03-07T00:00:00.000Z
GATEWAY_EXECUTOR_PRIVATE_KEY=
GATEWAY_EXECUTOR_TIMEOUT_MS=45000
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
GATEWAY_CORS_ALLOW_NO_ORIGIN=false
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_REDIS_URL=
# Local docker example only. Production must keep this false.
GATEWAY_ALLOW_INSECURE_DOWNSTREAM_AUTH=true
GATEWAY_ORACLE_BASE_URL=http://oracle:3002
GATEWAY_ORACLE_SERVICE_API_KEY=
GATEWAY_ORACLE_SERVICE_API_SECRET=
GATEWAY_TREASURY_BASE_URL=http://treasury:3008
GATEWAY_TREASURY_SERVICE_API_KEY=
GATEWAY_TREASURY_SERVICE_API_SECRET=
GATEWAY_RECONCILIATION_BASE_URL=http://reconciliation:9090
GATEWAY_RICARDIAN_BASE_URL=http://ricardian:3100/api/ricardian/v1
GATEWAY_RICARDIAN_SERVICE_API_KEY=
GATEWAY_RICARDIAN_SERVICE_API_SECRET=
GATEWAY_NOTIFICATIONS_BASE_URL=
GATEWAY_DOWNSTREAM_READ_RETRY_BUDGET=1
GATEWAY_DOWNSTREAM_MUTATION_RETRY_BUDGET=0
GATEWAY_DOWNSTREAM_READ_TIMEOUT_MS=5000
GATEWAY_DOWNSTREAM_MUTATION_TIMEOUT_MS=8000

# Real indexer pipeline (used by staging-e2e / staging-e2e-real).
# The active pilot target is Base Sepolia. Do not use historical Asset Hub
# Paseo or public Base RPC defaults for the controlled pilot runtime.
# Optional archive gateway for accelerated indexing. Leave blank when running
# the EVM processor directly against RPC only.
INDEXER_GATEWAY_URL=https://managed-base-sepolia-indexer.example.invalid
INDEXER_RPC_ENDPOINT=https://managed-base-sepolia-rpc-primary.example.invalid
INDEXER_START_BLOCK=39588005
INDEXER_RATE_LIMIT=10
INDEXER_RPC_CAPACITY=
INDEXER_RPC_MAX_BATCH_CALL_SIZE=
INDEXER_RPC_REQUEST_TIMEOUT_MS=
INDEXER_RPC_RETRY_ATTEMPTS=
INDEXER_RPC_HEAD_POLL_INTERVAL_MS=
INDEXER_RPC_INGEST_DISABLED=false
INDEXER_RPC_BLOCK_SPLIT_SIZE=10
# Squid still needs a processor-level confirmation window, but this is not the
# workflow / treasury truth source. Active Base confirmation policy remains the
# `safe` / `finalized` stage model from issue #377.
FINALITY_CONFIRMATION_BLOCKS=1
INDEXER_CONTRACT_ADDRESS=0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A

# Staging gate settings
STAGING_E2E_MAX_INDEXER_LAG_BLOCKS=500
STAGING_E2E_DRIFT_SUMMARY_LIMIT=10

# Staging e2e real gate context (active M4 target: Base Sepolia)
STAGING_E2E_REAL_NETWORK_NAME='Base Sepolia'
STAGING_E2E_REAL_CHAIN_ID=84532
STAGING_E2E_REAL_REQUIRE_INDEXED_DATA=false

# Asset conversion fee-path validation defaults
# local-dev is expected to use deterministic native fallback.
LOCAL_DEV_FEE_PATH_EXPECTED_BEHAVIOR=native-fallback
LOCAL_DEV_FEE_PATH_ALLOW_NATIVE_FALLBACK=true
LOCAL_DEV_FEE_PATH_CREATE_TX_HASH=
LOCAL_DEV_FEE_PATH_SETTLEMENT_TX_HASHES=

# staging-e2e-real targets usdc-preferred behavior; fallback can be allowed by policy.
STAGING_E2E_REAL_FEE_PATH_EXPECTED_BEHAVIOR=usdc-preferred
STAGING_E2E_REAL_FEE_PATH_ALLOW_NATIVE_FALLBACK=true
STAGING_E2E_REAL_FEE_PATH_CREATE_TX_HASH=
STAGING_E2E_REAL_FEE_PATH_SETTLEMENT_TX_HASHES=
