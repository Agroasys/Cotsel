{
  "name": "indexer",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf lib && tsc",
    "start": "node -r dotenv/config lib/main.js",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test ./tests/*.test.mjs"
  },
  "dependencies": {
    "@subsquid/evm-processor": "^1.30.1",
    "@subsquid/evm-typegen": "^5.0.0",
    "@subsquid/graphql-server": "^4.12.0",
    "@subsquid/typeorm-migration": "^1.3.1",
    "@subsquid/typeorm-store": "^1.9.1",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "pg": "8.22.0",
    "typeorm": "1.0.0"
  },
  "devDependencies": {
    "@subsquid/typeorm-codegen": "^2.2.0",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
