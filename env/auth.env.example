# Auth Service environment variables
# Copy to auth.env and fill in values before running.

# HTTP
PORT=3005

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agroasys_auth
DB_USER=cotsel_auth_app
DB_PASSWORD=local-auth-runtime-password
DB_MIGRATION_USER=cotsel_auth_migrator
DB_MIGRATION_PASSWORD=local-auth-migration-password

# Session — default lifetime in seconds (24 h)
SESSION_TTL_SECONDS=86400
AUTH_CORS_ALLOWED_ORIGINS=

# Compatibility-only wallet login. Enable only for local development or tests.
LEGACY_WALLET_LOGIN_ENABLED=false

# Browser edge policy
AUTH_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_CORS_ALLOW_NO_ORIGIN=false
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_REDIS_URL=

# Trusted upstream session exchange (optional; disabled by default)
TRUSTED_SESSION_EXCHANGE_ENABLED=false
TRUSTED_SESSION_EXCHANGE_API_KEYS_JSON=
TRUSTED_SESSION_EXCHANGE_MAX_SKEW_SECONDS=300
TRUSTED_SESSION_EXCHANGE_NONCE_TTL_SECONDS=600
