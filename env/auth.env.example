# Auth Service environment variables
# Copy to auth.env and fill in values before running.

# HTTP
PORT=3005

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agroasys_auth
DB_USER=postgres
DB_PASSWORD=postgres

# Session — default lifetime in seconds (24 h)
SESSION_TTL_SECONDS=86400

# Trusted upstream session exchange (optional; disabled by default)
TRUSTED_SESSION_EXCHANGE_ENABLED=false
TRUSTED_SESSION_EXCHANGE_API_KEYS_JSON=
TRUSTED_SESSION_EXCHANGE_MAX_SKEW_SECONDS=300
TRUSTED_SESSION_EXCHANGE_NONCE_TTL_SECONDS=600
