# Copy to .env.staging-e2e for staging release-gate profile overrides

# Service-scoped Postgres roles used by the containerized staging stack.
AUTH_DB_RUNTIME_USER=cotsel_auth_app
AUTH_DB_RUNTIME_PASSWORD=staging-auth-runtime-password
AUTH_DB_MIGRATION_USER=cotsel_auth_migrator
AUTH_DB_MIGRATION_PASSWORD=staging-auth-migration-password
RICARDIAN_DB_RUNTIME_USER=cotsel_ricardian_app
RICARDIAN_DB_RUNTIME_PASSWORD=staging-ricardian-runtime-password
RICARDIAN_DB_MIGRATION_USER=cotsel_ricardian_migrator
RICARDIAN_DB_MIGRATION_PASSWORD=staging-ricardian-migration-password
TREASURY_DB_RUNTIME_USER=cotsel_treasury_app
TREASURY_DB_RUNTIME_PASSWORD=staging-treasury-runtime-password
TREASURY_DB_MIGRATION_USER=cotsel_treasury_migrator
TREASURY_DB_MIGRATION_PASSWORD=staging-treasury-migration-password
RECONCILIATION_DB_RUNTIME_USER=cotsel_reconciliation_app
RECONCILIATION_DB_RUNTIME_PASSWORD=staging-reconciliation-runtime-password
RECONCILIATION_DB_MIGRATION_USER=cotsel_reconciliation_migrator
RECONCILIATION_DB_MIGRATION_PASSWORD=staging-reconciliation-migration-password
ORACLE_DB_RUNTIME_USER=cotsel_oracle_app
ORACLE_DB_RUNTIME_PASSWORD=staging-oracle-runtime-password
ORACLE_DB_MIGRATION_USER=cotsel_oracle_migrator
ORACLE_DB_MIGRATION_PASSWORD=staging-oracle-migration-password
GATEWAY_DB_RUNTIME_USER=cotsel_gateway_app
GATEWAY_DB_RUNTIME_PASSWORD=staging-gateway-runtime-password
GATEWAY_DB_MIGRATION_USER=cotsel_gateway_migrator
GATEWAY_DB_MIGRATION_PASSWORD=staging-gateway-migration-password

# staging-e2e must use real indexer GraphQL service
RECONCILIATION_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
TREASURY_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
ORACLE_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql

# Active Base staging inputs. Use managed provider URLs only.
# INDEXER_GATEWAY_URL is optional when the indexer runs directly against RPC.
INDEXER_GATEWAY_URL=https://managed-base-sepolia-indexer.example.invalid
INDEXER_RPC_ENDPOINT=https://managed-base-sepolia-rpc-primary.example.invalid
INDEXER_START_BLOCK=39588005
INDEXER_RATE_LIMIT=10
INDEXER_GRAPHQL_PORT=4350

# gateway / oracle / reconciliation must resolve to Base Sepolia in active staging
GATEWAY_SETTLEMENT_RUNTIME=base-sepolia
GATEWAY_RPC_URL=https://managed-base-sepolia-rpc-primary.example.invalid
GATEWAY_RPC_FALLBACK_URLS=https://managed-base-sepolia-rpc-fallback.example.invalid
GATEWAY_CHAIN_ID=84532
GATEWAY_EXPLORER_BASE_URL=https://sepolia-explorer.base.org/tx/
RECONCILIATION_SETTLEMENT_RUNTIME=base-sepolia
RECONCILIATION_RPC_URL=https://managed-base-sepolia-rpc-primary.example.invalid
RECONCILIATION_RPC_FALLBACK_URLS=https://managed-base-sepolia-rpc-fallback.example.invalid
RECONCILIATION_CHAIN_ID=84532
ORACLE_SETTLEMENT_RUNTIME=base-sepolia
ORACLE_RPC_URL=https://managed-base-sepolia-rpc-primary.example.invalid
ORACLE_RPC_FALLBACK_URLS=https://managed-base-sepolia-rpc-fallback.example.invalid
ORACLE_CHAIN_ID=84532
RECONCILIATION_REQUIRE_CONTAINER_SAFE_INDEXER_URL=false

# service auth defaults (disabled by default)
RICARDIAN_HMAC_SECRET=
TREASURY_HMAC_SECRET=
RICARDIAN_NONCE_STORE=postgres
TREASURY_NONCE_STORE=postgres

# replace with deployed addresses for full staging parity
RECONCILIATION_ESCROW_ADDRESS=0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A
RECONCILIATION_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
ORACLE_ESCROW_ADDRESS=0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A
ORACLE_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
GATEWAY_ESCROW_ADDRESS=0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A
GATEWAY_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
INDEXER_CONTRACT_ADDRESS=0x37F5d97fd9D227dd39391ACfC3C77FDF7c7F742A

# gate thresholds
STAGING_E2E_MAX_INDEXER_LAG_BLOCKS=500
STAGING_E2E_DRIFT_SUMMARY_LIMIT=10
