{
  "name": "reconciliation",
  "version": "1.0.0",
  "private": true,
  "main": "dist/cli.js",
  "scripts": {
    "build:sdk": "npm --prefix ../sdk run build",
    "build": "tsc",
    "prebuild": "npm run build:sdk",
    "lint": "eslint --max-warnings=0 .",
    "pretest": "npm run build:sdk",
    "typecheck": "tsc --noEmit",
    "test": "node -r ts-node/register --test src/tests/*.test.ts",
    "reconcile:once": "ts-node src/cli.ts once",
    "reconcile:daemon": "ts-node src/cli.ts daemon",
    "reconcile:report": "ts-node src/report-cli.ts",
    "healthcheck": "node dist/healthcheck.js"
  },
  "dependencies": {
    "@agroasys/shared-db": "^1.0.0",
    "@agroasys/sdk": "^1.0.0",
    "dotenv": "^17.4.1",
    "pg": "^8.20.0",
    "@agroasys/notifications": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": ">=6.0.2"
  },
  "license": "Apache-2.0"
}
