{
  "private": true,
  "name": "@agroasys/cotsel",
  "main": "sdk/dist/index.js",
  "module": "sdk/dist/index.js",
  "types": "sdk/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./sdk/dist/index.d.ts",
      "import": "./sdk/dist/index.js",
      "require": "./sdk/dist/index.js",
      "default": "./sdk/dist/index.js"
    },
    "./legacy": {
      "types": "./sdk/dist/legacy.d.ts",
      "import": "./sdk/dist/legacy.js",
      "require": "./sdk/dist/legacy.js",
      "default": "./sdk/dist/legacy.js"
    },
    "./rpc/failoverProvider": {
      "types": "./sdk/dist/rpc/failoverProvider.d.ts",
      "import": "./sdk/dist/rpc/failoverProvider.js",
      "require": "./sdk/dist/rpc/failoverProvider.js",
      "default": "./sdk/dist/rpc/failoverProvider.js"
    }
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10 <12"
  },
  "workspaces": [
    "auth",
    "contracts",
    "gateway",
    "indexer",
    "oracle",
    "sdk",
    "shared-http",
    "shared-edge",
    "shared-db",
    "shared-auth",
    "reconciliation",
    "notifications",
    "ricardian",
    "treasury"
  ],
  "scripts": {
    "build": "npm run build -w sdk",
    "lint": "eslint --max-warnings=0 .",
    "lint:fix": "eslint --max-warnings=0 --fix .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "bash -lc 'files=$(git diff --name-only --diff-filter=ACMR HEAD); if [ -z \"$files\" ]; then echo \"No changed files to check\"; else npx prettier --check --ignore-unknown $files; fi'",
    "format:check:full": "prettier --check .",
    "prepare": "husky && npm run build",
    "dashboard:parity:session": "node scripts/dashboard-operator-session.mjs",
    "dashboard:parity:preflight": "node scripts/dashboard-local-parity-preflight.mjs",
    "dashboard:parity:gate": "npm run dashboard:parity:preflight",
    "dashboard:parity:ci": "bash scripts/dashboard-live-parity-gate.sh",
    "m3:continuity:ci": "bash scripts/m3-continuity-gate.sh",
    "pilot:rehearsal": "bash scripts/base-sepolia-pilot-validation.sh",
    "licenses:report": "node scripts/generate-license-report.mjs",
    "security:deps": "node scripts/security-deps-report.mjs",
    "security:deps:gate": "node scripts/security-deps-gate.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "bn.js": "5.2.3",
    "defu": "6.1.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "lodash": "4.18.1",
    "prettier": "^3.8.2",
    "typescript-eslint": "^8.59.0",
    "undici": "8.1.0",
    "viem": "2.48.2"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts}": [
      "eslint --max-warnings=0 --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "axios": "1.15.0",
    "hardhat-gas-reporter": {
      "axios": "1.15.0"
    },
    "brace-expansion@^1.1.7": "1.1.14",
    "brace-expansion@^2.0.1": "2.1.0",
    "brace-expansion@^2.0.2": "2.1.0",
    "brace-expansion@>=4 <5.0.5": "5.0.5",
    "hardhat": "2.28.6",
    "@nomicfoundation/hardhat-ethers": "3.1.3",
    "@nomicfoundation/hardhat-verify": "2.1.3",
    "@nomicfoundation/hardhat-network-helpers": "1.1.2",
    "@nomicfoundation/hardhat-ignition": "0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "0.15.17",
    "handlebars@<4.7.9": "4.7.9",
    "immutable": "4.3.8",
    "picomatch@<2.3.2": "2.3.2",
    "picomatch@>=4 <4.0.4": "4.0.4",
    "path-to-regexp@<0.1.13": "0.1.13",
    "path-to-regexp@>=8 <8.4.0": "8.4.0",
    "defu": "6.1.7",
    "elliptic": {
      "bn.js": "4.12.3"
    },
    "ethjs-unit": {
      "bn.js": "4.11.6"
    },
    "number-to-bn": {
      "bn.js": "4.11.6"
    },
    "tiny-secp256k1": {
      "bn.js": "4.12.3"
    }
  }
}
