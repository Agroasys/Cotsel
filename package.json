{
  "private": true,
  "name": "@agroasys/cotsel",
  "main": "sdk/dist/index.js",
  "module": "sdk/dist/index.js",
  "types": "sdk/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./sdk/dist/index.d.ts",
      "import": "./sdk/dist/index.js",
      "require": "./sdk/dist/index.js",
      "default": "./sdk/dist/index.js"
    },
    "./legacy": {
      "types": "./sdk/dist/legacy.d.ts",
      "import": "./sdk/dist/legacy.js",
      "require": "./sdk/dist/legacy.js",
      "default": "./sdk/dist/legacy.js"
    },
    "./rpc/failoverProvider": {
      "types": "./sdk/dist/rpc/failoverProvider.d.ts",
      "import": "./sdk/dist/rpc/failoverProvider.js",
      "require": "./sdk/dist/rpc/failoverProvider.js",
      "default": "./sdk/dist/rpc/failoverProvider.js"
    }
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20 <23",
    "npm": ">=10 <12"
  },
  "workspaces": [
    "auth",
    "contracts",
    "gateway",
    "indexer",
    "oracle",
    "sdk",
    "shared-auth",
    "reconciliation",
    "notifications",
    "ricardian",
    "treasury"
  ],
  "scripts": {
    "build": "npm run build -w sdk",
    "lint": "npm run lint --workspaces --if-present",
    "prepare": "npm run build",
    "dashboard:parity:session": "node scripts/dashboard-operator-session.mjs",
    "dashboard:parity:preflight": "node scripts/dashboard-local-parity-preflight.mjs",
    "dashboard:parity:gate": "npm run dashboard:parity:preflight",
    "dashboard:parity:ci": "bash scripts/dashboard-live-parity-gate.sh",
    "m3:continuity:ci": "bash scripts/m3-continuity-gate.sh",
    "pilot:rehearsal": "bash scripts/base-sepolia-pilot-validation.sh",
    "licenses:report": "node scripts/generate-license-report.mjs",
    "security:deps": "node scripts/security-deps-report.mjs"
  },
  "devDependencies": {
    "defu": "6.1.6",
    "lodash": "4.18.1",
    "undici": "6.24.0"
  },
  "overrides": {
    "axios": "1.14.0",
    "@parity/hardhat-polkadot-node": {
      "axios": "1.14.0"
    },
    "@parity/hardhat-polkadot-resolc": {
      "axios": "1.14.0"
    },
    "hardhat-gas-reporter": {
      "axios": "1.14.0"
    },
    "bn.js": "5.2.3",
    "brace-expansion@<1.1.13": "1.1.13",
    "brace-expansion@>=2 <2.0.3": "2.0.3",
    "brace-expansion@>=4 <5.0.5": "5.0.5",
    "hardhat": "2.28.6",
    "@nomicfoundation/hardhat-ethers": "3.1.3",
    "@nomicfoundation/hardhat-verify": "2.1.3",
    "@nomicfoundation/hardhat-network-helpers": "1.1.2",
    "@nomicfoundation/hardhat-ignition": "0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "0.15.17",
    "glob": "11.1.0",
    "handlebars@<4.7.9": "4.7.9",
    "immutable": "4.3.8",
    "minimatch": "10.2.3",
    "picomatch@<2.3.2": "2.3.2",
    "picomatch@>=4 <4.0.4": "4.0.4",
    "path-to-regexp@<0.1.13": "0.1.13",
    "path-to-regexp@>=8 <8.4.0": "8.4.0",
    "serialize-javascript": "7.0.5",
    "defu": "6.1.6",
    "lodash": "4.18.1",
    "undici": "6.24.0",
    "@nomicfoundation/ignition-core": {
      "lodash": "4.18.1"
    }
  }
}
