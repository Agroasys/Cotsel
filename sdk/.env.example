# network config
# Use SETTLEMENT_RUNTIME for the canonical Base runtime and override the
# transport or explorer roots only when a deployment environment requires it.
SETTLEMENT_RUNTIME=
RPC_URL=
RPC_FALLBACK_URLS=
CHAIN_ID=
EXPLORER_BASE_URL=

# addresses
ESCROW_ADDRESS=
USDC_ADDRESS=
SUPPLIER_ADDRESS=

# test wallets
BUYER_PRIVATE_KEY=
ORACLE_PRIVATE_KEY=
ADMIN1_PRIVATE_KEY=
ADMIN2_PRIVATE_KEY=

# optional manual e2e toggles
RUN_E2E=false
RUN_ADMIN_MUTATION_E2E=false
RUN_BUYER_CLAIM_E2E=false
RUN_BUYER_DISPUTE_E2E=false
RUN_BUYER_TIMEOUT_E2E=false

# optional manual admin mutation fixtures
TEST_TRADE_ID=
TEST_DISPUTE_PROPOSAL_ID=
TEST_ORACLE_PROPOSAL_ID=
TEST_ADMIN_ADD_PROPOSAL_ID=
TEST_TREASURY_PAYOUT_PROPOSAL_ID=
TEST_NEW_ORACLE_ADDRESS=
TEST_NEW_ADMIN_ADDRESS=
TEST_NEW_TREASURY_PAYOUT_ADDRESS=

# optional manual buyer mutation fixtures
TEST_DISPUTE_TRADE_ID=
TEST_LOCKED_TRADE_ID=
TEST_IN_TRANSIT_TRADE_ID=

# web3auth
CLIENT_ID=
WEB3AUTH_NETWORK=SAPPHIRE_DEVNET
