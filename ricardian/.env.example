PORT=3100

DB_HOST=localhost
DB_PORT=5432
DB_NAME=agroasys_ricardian
DB_USER=cotsel_ricardian_app
DB_PASSWORD=local-ricardian-runtime-password
DB_MIGRATION_USER=cotsel_ricardian_migrator
DB_MIGRATION_PASSWORD=local-ricardian-migration-password

# Disable only for isolated local development. Production defaults to true.
AUTH_ENABLED=false
API_KEYS_JSON=[]
# Example: API_KEYS_JSON=[{"id":"ricardian-internal","secret":"replace-with-secret","active":true}]
# NOTE: active must be explicit boolean true/false for each key.
HMAC_SECRET=
AUTH_MAX_SKEW_SECONDS=300
AUTH_NONCE_TTL_SECONDS=600
NONCE_STORE=inmemory
REDIS_URL=
NONCE_TTL_SECONDS=600
RICARDIAN_CORS_ALLOWED_ORIGINS=
RICARDIAN_CORS_ALLOW_NO_ORIGIN=false

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_WRITE_BURST_LIMIT=10
RATE_LIMIT_WRITE_BURST_WINDOW_SECONDS=10
RATE_LIMIT_WRITE_SUSTAINED_LIMIT=120
RATE_LIMIT_WRITE_SUSTAINED_WINDOW_SECONDS=60
RATE_LIMIT_READ_BURST_LIMIT=30
RATE_LIMIT_READ_BURST_WINDOW_SECONDS=10
RATE_LIMIT_READ_SUSTAINED_LIMIT=600
RATE_LIMIT_READ_SUSTAINED_WINDOW_SECONDS=60
