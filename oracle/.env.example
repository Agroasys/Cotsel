# server
PORT=
API_KEY=
HMAC_SECRET=

# network
# Canonical runtime selector for active Base environments. Use a known runtime
# key (for example `base-sepolia`) or provide explicit RPC/CHAIN_ID overrides.
SETTLEMENT_RUNTIME=
# Optional primary RPC override. Required for custom runtimes; otherwise falls
# back to the selected runtime default.
RPC_URL=
RPC_FALLBACK_URLS=
CHAIN_ID=
EXPLORER_BASE_URL=
ESCROW_ADDRESS=
USDC_ADDRESS=
ORACLE_PRIVATE_KEY=

# oracle db
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# indexer graphql api
INDEXER_GRAPHQL_URL=

# retry config
RETRY_ATTEMPTS=
RETRY_DELAY=
# notifications (optional)
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_WEBHOOK_URL=
NOTIFICATIONS_COOLDOWN_MS=300000
NOTIFICATIONS_REQUEST_TIMEOUT_MS=5000
