{
  "name": "oracle",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run copy-files",
    "copy-files": "mkdir -p dist/database && cp src/database/schema.sql dist/database/",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "pretest": "npm run build:sdk",
    "test": "jest --runInBand",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "tsc --noEmit",
    "build:sdk": "npm --prefix ../sdk run build",
    "prebuild": "npm run build:sdk"
  },
  "dependencies": {
    "@agroasys/shared-db": "^1.0.0",
    "@agroasys/shared-http": "^1.0.0",
    "@agroasys/shared-edge": "^1.0.0",
    "express": "^5.2.1",
    "cors": "^2.8.6",
    "helmet": "^8.2.0",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "pg": "^8.22.0",
    "@agroasys/sdk": "^1.0.0",
    "@agroasys/notifications": "^1.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.17",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "typescript": ">=7.0.2",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.14",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11"
  },
  "license": "Apache-2.0"
}
