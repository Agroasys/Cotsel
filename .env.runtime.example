GATEWAY_SETTLEMENT_RUNTIME=base-sepolia
GATEWAY_RPC_URL=
GATEWAY_RPC_FALLBACK_URLS=
# Optional: require N-provider agreement for reads (default 1 = first answer wins).
# Clamped to the number of configured endpoints, so it can never block startup.
GATEWAY_RPC_QUORUM=
GATEWAY_CHAIN_ID=84532
GATEWAY_EXPLORER_BASE_URL=https://sepolia-explorer.base.org/tx/

# In-network GraphQL endpoints (never localhost inside containers)
RECONCILIATION_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
TREASURY_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql
ORACLE_INDEXER_GRAPHQL_URL=http://indexer-graphql:4350/graphql

# Active Base Sepolia managed-provider inputs.
# INDEXER_GATEWAY_URL is optional when the indexer runs directly against RPC.
INDEXER_GATEWAY_URL=
INDEXER_RPC_ENDPOINT=
# Optional comma-separated fallback RPC endpoints (priority order). The indexer
# can only use one URL at a time, so it picks the first reachable one at startup.
INDEXER_RPC_FALLBACK_ENDPOINTS=
INDEXER_START_BLOCK=41078828
INDEXER_RATE_LIMIT=10
INDEXER_RPC_CAPACITY=
INDEXER_RPC_MAX_BATCH_CALL_SIZE=
INDEXER_RPC_REQUEST_TIMEOUT_MS=
INDEXER_RPC_RETRY_ATTEMPTS=
INDEXER_RPC_HEAD_POLL_INTERVAL_MS=
INDEXER_RPC_INGEST_DISABLED=false
INDEXER_RPC_BLOCK_SPLIT_SIZE=10
FINALITY_CONFIRMATION_BLOCKS=1
INDEXER_GRAPHQL_PORT=4350

# Chain context used by validation reporting
STAGING_E2E_REAL_NETWORK_NAME='Base Sepolia'
STAGING_E2E_REAL_CHAIN_ID=84532

# Reconciliation/oracle pilot runtime (managed primary + independent fallback)
RECONCILIATION_SETTLEMENT_RUNTIME=base-sepolia
RECONCILIATION_RPC_URL=
RECONCILIATION_RPC_FALLBACK_URLS=
# Optional RPC failover tuning (defaults: quorum 1, stall 1500ms).
RECONCILIATION_RPC_QUORUM=
RECONCILIATION_RPC_STALL_TIMEOUT_MS=
RECONCILIATION_CHAIN_ID=84532
ORACLE_SETTLEMENT_RUNTIME=base-sepolia
ORACLE_RPC_URL=
ORACLE_RPC_FALLBACK_URLS=
# Optional RPC failover tuning (defaults: quorum 1, stall 1500ms).
ORACLE_RPC_QUORUM=
ORACLE_RPC_STALL_TIMEOUT_MS=
